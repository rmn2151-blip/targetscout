# NCBI E-utilities (PubMed). Email required; API key optional (raises rate limit to 10 req/s).
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# LLM provider for synthesis (choose one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Postgres + pgvector
DATABASE_URL=postgresql://targetscout:targetscout@localhost:5432/targetscout

# Optional managed vector DB
PINECONE_API_KEY=

# Langfuse tracing (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# MLflow
MLFLOW_TRACKING_URI=file:./mlruns
